# ============================================
# CLIENT ENVIRONMENT VARIABLES (Next.js)
# ============================================
# Copy this file to .env.local for local development
# For Vercel: add these in the project settings → Environment Variables
#
# NOTE: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Never put secrets here — only public URLs.

# Backend API URL (must end with /api)
# Local:       http://localhost:3001/api
# Production:  https://your-backend.up.railway.app/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Backend Socket.io URL (without /api suffix)
# Local:       http://localhost:3001
# Production:  https://your-backend.up.railway.app
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
