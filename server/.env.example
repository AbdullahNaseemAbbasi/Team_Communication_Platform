# ============================================
# SERVER ENVIRONMENT VARIABLES (NestJS)
# ============================================
# Copy this file to .env for local development.
# For Railway/Render: add these in the service settings → Variables.

# ---- Server ----
PORT=3001
NODE_ENV=development

# ---- Database ----
# Local:       mongodb://localhost:27017/team-chat
# Production:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/team-chat (MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/team-chat

# ---- JWT (generate with: openssl rand -base64 48) ----
JWT_SECRET=replace_with_secure_random_string_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_secure_random_string_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ---- CORS / Frontend URL ----
# Local:       http://localhost:3000
# Production:  https://your-frontend.vercel.app
CLIENT_URL=http://localhost:3000
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# ---- Google OAuth (optional) ----
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
# Production callback URL must match exactly what is registered in Google Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ---- Cloudinary (file/avatar uploads) ----
# Sign up free at https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Email (SMTP for OTP verification) ----
# For Gmail: enable 2FA → create App Password at https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@teamchat.com
